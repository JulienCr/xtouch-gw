{
  "name": "com.juliencr.xtouch-gw",
  "version": "1.7.0",
  "description": "Stream Deck plugin for XTouch GW camera control",
  "main": "bin/plugin.js",
  "type": "module",
  "scripts": {
    "build": "rollup -c",
    "watch": "rollup -c -w",
    "clean": "rimraf bin/*.js bin/*.map",
    "install-plugin": "rollup -c && npx @elgato/cli link",
    "restart-plugin": "npx @elgato/cli restart com.juliencr.xtouch-gw"
  },
  "dependencies": {
    "@elgato/streamdeck": "^1.0.0",
    "@napi-rs/canvas": "^0.1.90",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-typescript": "^11.1.6",
    "@types/node": "^20.11.0",
    "@types/ws": "^8.18.1",
    "rimraf": "^5.0.5",
    "rollup": "^4.9.6",
    "tslib": "^2.6.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@napi-rs/canvas"
    ]
  }
}
